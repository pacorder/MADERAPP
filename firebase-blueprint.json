{
  "entities": {
    "Project": {
      "title": "Proyecto de Mueble",
      "description": "Un proyecto que contiene varios muebles y sus piezas",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "clientName": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "items": { "type": "array" }
      },
      "required": ["userId", "name", "items"]
    }
  },
  "firestore": {
    "projects": {
      "schema": "Project",
      "description": "Colección de proyectos de los usuarios"
    }
  }
}
